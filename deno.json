{
  "nodeModulesDir": "manual",
  "tasks": {
    "check": "deno fmt --check . && deno lint . && deno check",
    "dev": "vite",
    "build": "vite build",
    "start": "deno serve -A _fresh/server.js",
    "update": "deno run -A -r jsr:@fresh/update .",
    "deploy": "deno run -A scripts/deploy.ts",
    "deploy:stag": "DEPLOY_ENV=staging deno run -A scripts/deploy.ts",
    "env:encrypt": "deno run -A scripts/encrypt.ts",
    "env:decrypt": "deno run -A scripts/decrypt.ts",
    "publish:blog": "deno run -A scripts/publish-blog.ts"
  },
  "lint": {
    "rules": {
      "tags": ["fresh", "recommended"],
      "exclude": ["react-no-danger"]
    }
  },
  "exclude": ["**/_fresh/*"],
  "imports": {
    "@/": "./",
    "@std/front-matter": "jsr:@std/front-matter@^1.0.9",
    "@tailwindcss/vite": "npm:@tailwindcss/vite@^4.1.18",
    "fresh": "jsr:@fresh/core@^2.3.3",
    "marked": "npm:marked@^17.0.1",
    "preact": "npm:preact@^10.29.1",
    "@preact/signals": "npm:@preact/signals@^2.9.0",
    "@fresh/plugin-vite": "jsr:@fresh/plugin-vite@^1.0.8",
    "tailwindcss": "npm:tailwindcss@^4.1.18",
    "vite": "npm:vite@^7.1.3"
  },
  "compilerOptions": {
    "lib": ["dom", "dom.asynciterable", "dom.iterable", "deno.ns"],
    "jsx": "precompile",
    "jsxImportSource": "preact",
    "jsxPrecompileSkipElements": [
      "a",
      "img",
      "source",
      "body",
      "html",
      "head",
      "title",
      "meta",
      "script",
      "link",
      "style",
      "base",
      "noscript",
      "template"
    ],
    "types": ["vite/client"]
  }
}
